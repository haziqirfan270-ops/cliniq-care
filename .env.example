# Copy this file to ".env" and fill in your values.

# Hugging Face Inference API token (free) - enables natural-language symptom
# understanding in the chatbot. Get one at https://huggingface.co/settings/tokens
# Without it, the chatbot still works using offline keyword matching.
HF_TOKEN=

# Optional: override the zero-shot model used for symptom extraction.
HF_MODEL=facebook/bart-large-mnli

# Flask session secret (set a random value in production).
SECRET_KEY=cliniq-care-dev-secret
